# =============================================================================
# LG Load Optimizer - Environment template
# Copy to .env and fill in values. DO NOT commit .env to git.
# =============================================================================

# Environment
ENV=development                          # development | staging | production
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR

# Email / SMTP (see docs/EMAIL_SETUP.md for provider-specific config)
SMTP_HOST=smtp.office365.com             # smtp.office365.com | smtp.gmail.com | etc.
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=load-optimizer@lg.com
SMTP_PASSWORD=CHANGE_ME_USE_APP_PASSWORD
SMTP_FROM_ADDRESS=load-optimizer@lg.com
SMTP_FROM_NAME="LG Load Optimizer"

# Phase 1: Database
DATABASE_URL=postgresql://load_optimizer:CHANGE_ME@localhost:5432/load_optimizer

# Phase 1: Auth
SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
SSO_PROVIDER=saml                        # saml | oauth | none
SAML_IDP_URL=https://lg.okta.com/...
SAML_CERT_PATH=/etc/ssl/certs/saml.crt

# Phase 1: Storage (for generated PDF reports)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Phase 2: ERP integration
SAP_API_URL=
SAP_API_KEY=
